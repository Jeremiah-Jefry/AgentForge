generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("MEMBER") // ADMIN | MANAGER | MEMBER
  avatarUrl    String?
  status       String   @default("Online") // Online | Away | Focus | Offline
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasks      Task[]
  activities Activity[]
}

model Client {
  id          String   @id @default(cuid())
  name        String
  project     String
  stage       String   @default("Discovery") // Discovery | In progress | Review | Delivered | On track
  payment     String   @default("Pending") // Paid | Pending | Upcoming | Overdue
  performance String   @default("0%")
  health      String   @default("0%")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoices Invoice[]
}

model Task {
  id        String   @id @default(cuid())
  title     String
  owner     String
  due       String
  column    String   @default("TODO") // TODO | PROGRESS | DONE
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  date          String
  amount        String
  status        String   @default("Pending") // Paid | Pending | Overdue
  clientId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
}

model Activity {
  id        String   @id @default(cuid())
  title     String
  detail    String
  time      String
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
